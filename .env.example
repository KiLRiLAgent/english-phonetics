# Whisper model for transcription
# Options: tiny, base, small, medium, large, large-v2, large-v3, large-v3-turbo
WHISPER_MODEL=large-v3-turbo

# OpenAI API key for AI grammar filtering (gpt-4o-mini)
# Get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# Optional: AI model for grammar filtering (default: gpt-4o-mini)
# AI_MODEL=gpt-4o-mini

# Optional: Use AI filter (default: true)
# USE_AI_FILTER=true
